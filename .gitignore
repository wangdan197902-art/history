.cache/
*.log

# Hugo
site/public/
site/resources/
site/.hugo_build.lock
# 生成的内容(220,000+ 文件,860MB)由 GitHub Actions 部署时动态生成
site/content/

# Node
node_modules/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 性能报告
perf_reports/
*.prof

# 临时测试目录
/tmp/test_content

# ========== 补充：macOS resource forks / Hugo 构建产物 / 多语言输出 ==========

# macOS resource forks（匹配 site/._.hugo_build.lock, site/._hugo_stats.json 等）
**/._*
._*

# Hugo 构建产物（site/ 前缀，与现有 Hugo 段保持一致）
site/hugo_stats.json
site/_hugo_stats.json

# 多语言构建输出目录
site/public-*/

# macOS 资源 fork 副本（显式）
site/._resources

# 环境变量示例文件
.env.local.example

# LLM 配置(包含 API Key,用户本地填写,不提交)
# llm.config.example.toml 是占位符版本,会被提交
# llm.config.toml 是实际值版本,被排除
llm.config.toml

# LLM 翻译缓存(diskcache 自动生成)
.cache/llm_translations/

