# ===========================================
# 环境配置 - 地区化今天历史档案站
# 复制此文件为 .env 并按需修改
# ===========================================

# 环境: local | production
ENV=local

# Mock Server
MOCK_SERVER_HOST=127.0.0.1
MOCK_SERVER_PORT=8765

# Provider 切换 (mock | real)
WIKIPEDIA_PROVIDER=mock
ANTHROPIC_PROVIDER=mock
OPENAI_PROVIDER=mock
GEMINI_PROVIDER=mock
BUTTONDOWN_PROVIDER=mock
GSC_PROVIDER=mock

# 管道并发
ASYNCIO_SEMAPHORE=16
DISKCACHE_DIR=.cache/pipeline

# Hugo
HUGO_CACHE_DIR=~/.cache/hugo-today-in-history

# 内容范围
COUNTRIES=CN,US,JP,KR,UK,DE,FR,RU,BR,IN,AU,CA,IT,ES,MX,ID,TH,VN,SG,MY,PH,SA,AE,EG,ZA,NG,TR,PL,NL,SE
LANGUAGES=zh,en,ja,ko,es,fr,de,pt,ru,ar

# 故障注入测试 (可选)
FAULT_INJECTION_ENABLED=false
FAULT_INJECTION_RATE=0.0

# 生产环境 (Phase 4 启用,留空即可)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# BUTTONDOWN_API_KEY=
# WIKIPEDIA_USER_AGENT=
# GSC_SERVICE_ACCOUNT_JSON=
